# Cluster Configuration
# CLUSTER_TYPE: k3s or aks
CLUSTER_TYPE=k3s

# AKS Configuration (Required if CLUSTER_TYPE=aks)
AZURE_RESOURCE_GROUP=my-runners-rg
AZURE_CLUSTER_NAME=ci-stress-test-cluster
AZURE_REGION=eastus

# GitHub Runner Configuration
# URL to your repository (e.g., https://github.com/user/repo)
GITHUB_REPO_URL=
# GitHub Runner Registration Token (obtained from Repo -> Settings -> Actions -> Runners -> New self-hosted runner)
GITHUB_RUNNER_TOKEN=

# GitLab Runner Configuration
# URL to your GitLab instance (e.g., https://gitlab.com)
GITLAB_URL=https://gitlab.com
# GitLab Registration Token (obtained from Project -> Settings -> CI/CD -> Runners)
GITLAB_REGISTRATION_TOKEN=

# Jenkins Agent Configuration
# URL to your Jenkins Controller (e.g., http://jenkins-controller:8080)
JENKINS_URL=
# Name of the agent configured in Jenkins
JENKINS_AGENT_NAME=stress-runner
# Secret for the inbound agent (obtained from Node configuration)
JENKINS_SECRET=
